        "prefix": "GetFromDB",
        "description": "ET 从数据库查询单条数据（扩展方法）",
        "body": [
            "/// <summary>数据库查找数据 </summary>",
            "public static async ETTask<${1:classname1}> GetFromDB(this ${2:classname2} self, long accountId)",
            "{",
            "    var dbItem = await DBManagerComponent.Instance.GetZoneDB(self.DomainScene().DomainZone())",
            "        .Query<${1:classname1}>(d => d.account_id == accountId);",
            "    return dbItem.FirstOrDefault();",
            "}"
