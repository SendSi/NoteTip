    "serverEntityComps": {
        "prefix": "serverEntityComps",
        "description": "服务器端实体组件",
        "body": [
            "/// <summary> 1缓存取 2数据库取 3创建实体并创数据库		 </summary>",
            "public static async ETTask<$classname$_entity> Get_Entity(this ${TM_FILENAME_BASE/(System)$//} self, long accountId)",
            "{",
            "    using (await CoroutineLockComponent.Instance.Wait(CoroutineLockType.GetTest, accountId))",
            "    {",
            "        if (self.UserEntityDic.TryGetValue(accountId, out long entityId))",
            "        {",
            "            var bag = self.GetChild<$classname$_entity>(entityId);",
            "            if (bag != null) return bag;",
            "        }",
            "        var db = DBManagerComponent.Instance.GetZoneDB(self.DomainZone());",
            "        var list = await db.Query<$classname$_entity>(e => e.account_id == accountId);",
            "        $classname$_entity entity = list.FirstOrDefault();",
            "        if (entity != null)",
            "        {",
            "            self.AddChild(entity);//这个得加入 不然会报错",
            "            self.UserEntityDic[accountId] = entity.Id;",
            "            return entity;",
            "        }",
            "        entity = self.AddChild<$classname$_entity>();//这个得加入  不然会报错",
            "        entity.account_id = accountId;",
            "        self.UserEntityDic[accountId] = entity.Id;",
            "        await db.Save(entity);",
            "        return entity;",
            "    }",
            "}",
            "/// <summary> 更新数据至数据库  </summary>",
            "private static void UpdateToDB(this ${TM_FILENAME_BASE/(System)$//} self, $classname$_entity entity)",
            "{",
            "    EventSystem.Instance.Publish(self.DomainScene(), new SaveDataToDB() { Entity = entity });",
            "}",
            "/// <summary>数据库查找数据 </summary>",
            "public static async ETTask<$classname$_entity> GetFromDB(this ${TM_FILENAME_BASE/(System)$//} self, long accountId)",
            "{",
            "    var dbItem = await DBManagerComponent.Instance.GetZoneDB(self.DomainScene().DomainZone()).Query<$classname$_entity>(d => d.account_id == accountId);",
            "    return dbItem.FirstOrDefault();",
            "}"
        ]
    },
